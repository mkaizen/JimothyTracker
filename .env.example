# Reddit scraper settings (all optional — copy to .env to override).
# The scraper drives a headless Chromium; no API keys or login are needed.
# Run `npm run setup` once first to download the browser.

# Which subreddits to search, comma-separated.
REDDIT_SUBREDDITS=Seattle,SeattleWA

# Search terms.
REDDIT_QUERY=jimothy raccoon

# Max posts to pull per subreddit.
REDDIT_LIMIT=25

# Show the browser window instead of running headless (handy for debugging
# if Reddit starts showing a robot/login wall). Set to 1 to enable.
# REDDIT_HEADFUL=1

# Override the browser User-Agent if you like.
# REDDIT_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) ...
